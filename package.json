{
  "name": "credit-safe-create-assistant",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "DATABASE_URL=file:./dev.db prisma generate && DATABASE_URL=file:./dev.db next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "DATABASE_URL=file:./dev.db prisma generate && tsc --noEmit",
    "test": "DATABASE_URL=file:./dev.db prisma generate && DATABASE_URL=file:./dev.db prisma db push --skip-generate && DATABASE_URL=file:./dev.db vitest run",
    "test:e2e": "DATABASE_URL=file:./dev.db prisma generate && DATABASE_URL=file:./dev.db playwright test",
    "prisma:generate": "DATABASE_URL=file:./dev.db prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "DATABASE_URL=file:./dev.db prisma db push"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "latest",
    "dotenv": "^17.4.2",
    "next": "latest",
    "prisma": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.32",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.10",
    "prisma": "^6.10.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "@playwright/test": "^1.57.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
